<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════════════
         TOP STATUS BAR
         ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/fire_red_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/robotTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚒 ROBOT"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/modeToggleButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mode_manual"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_toggle_manual"
            app:iconTint="@null"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:minHeight="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/statusRightPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/connectionStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/disconnected"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingEnd="8dp" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.335" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.665" />

    <!-- ═══════════════════════════════════════════════════════
         LEFT PANEL  —  DRIVE CONTROLS (F/B ARROWS)
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/movementPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideLeft">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DRIVE"
            android:textColor="@color/safety_yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/arrow_up_float"
            android:background="@drawable/btn_arrow_selector"
            android:layout_marginBottom="24dp" />

        <ImageButton
            android:id="@+id/btnBackward"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="@drawable/btn_arrow_selector" />
    </LinearLayout>

    <View
        android:id="@+id/dividerLeft"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideLeft" />

    <!-- ═══════════════════════════════════════════════════════
         CENTER PANEL  —  CONTROL BUTTONS
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideLeft"
        app:layout_constraintEnd_toStartOf="@id/guideRight">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pumpButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp"
            android:text="💧 PUMP"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/red_inactive" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/lightsButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="12dp"
            android:text="💡 LIGHTS"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/red_inactive" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/hornButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="📢 HORN"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/fire_orange" />

    </LinearLayout>

    <View
        android:id="@+id/dividerRight"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideRight" />

    <!-- ═══════════════════════════════════════════════════════
         RIGHT PANEL  —  STEERING + NOZZLE
         ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nozzlePanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideRight"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/labelSteerNoz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEER / NOZZLE"
            android:textColor="@color/safety_yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btnNozzleUp"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/arrow_up_float"
            android:background="@drawable/btn_arrow_selector"
            app:layout_constraintTop_toBottomOf="@id/labelSteerNoz"
            app:layout_constraintBottom_toTopOf="@id/btnNozzleDown"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="8dp" />

        <ImageButton
            android:id="@+id/btnTurnLeft"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/btn_arrow_selector"
            app:layout_constraintTop_toTopOf="@id/btnNozzleUp"
            app:layout_constraintBottom_toBottomOf="@id/btnNozzleDown"
            app:layout_constraintEnd_toStartOf="@id/btnNozzleUp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnTurnRight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_media_next"
            android:background="@drawable/btn_arrow_selector"
            app:layout_constraintTop_toTopOf="@id/btnNozzleUp"
            app:layout_constraintBottom_toBottomOf="@id/btnNozzleDown"
            app:layout_constraintStart_toEndOf="@id/btnNozzleUp"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btnNozzleDown"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="@drawable/btn_arrow_selector"
            app:layout_constraintTop_toBottomOf="@id/btnNozzleUp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
