<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════════════
         TOP STATUS BAR
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:background="@color/fire_red_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚒 FIREFIGHTER ROBOT"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Connection status dot + label -->
        <TextView
            android:id="@+id/connectionStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disconnected"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingEnd="16dp" />

        <!-- Settings gear -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="@color/white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         VERTICAL GUIDELINES  (33% | 33% | 33%)
         ═══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideLeft"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.335" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideRight"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.665" />

    <!-- ═══════════════════════════════════════════════════════
         LEFT PANEL  —  MOVEMENT JOYSTICK
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/movementPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideLeft">

        <!-- Section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_movement"
            android:textColor="@color/safety_yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp" />

        <!-- Joystick widget -->
        <com.firefighter.robotcontroller.JoystickView
            android:id="@+id/movementJoystick"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="6dp" />

        <!-- Hint text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_movement_hint"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Left | Center thin divider -->
    <View
        android:id="@+id/dividerLeft"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideLeft" />

    <!-- ═══════════════════════════════════════════════════════
         CENTER PANEL  —  CONTROL BUTTONS
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideLeft"
        app:layout_constraintEnd_toStartOf="@id/guideRight">

        <!-- Section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_controls"
            android:textColor="@color/safety_yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="10dp" />

        <!-- ── SUPPRESS FIRE ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/pumpButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:text="💧 SUPPRESS\nFIRE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/red_inactive"
            app:rippleColor="#33FFFFFF" />

        <!-- ── LIGHTS ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/lightsButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:text="💡 LIGHTS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/red_inactive"
            app:rippleColor="#33FFFFFF" />

        <!-- ── HORN (hold) ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/hornButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp"
            android:text="📢 HORN\n(HOLD)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/fire_orange"
            app:rippleColor="#33FFFFFF" />

        <!-- ── EMERGENCY STOP ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/emergencyStopButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="⛔ E-STOP"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            app:cornerRadius="14dp"
            app:backgroundTint="@color/fire_red"
            app:strokeColor="@color/safety_yellow"
            app:strokeWidth="2dp"
            app:rippleColor="#55FDD835" />

    </LinearLayout>

    <!-- Center | Right thin divider -->
    <View
        android:id="@+id/dividerRight"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideRight" />

    <!-- ═══════════════════════════════════════════════════════
         RIGHT PANEL  —  NOZZLE AIM JOYSTICK
         ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/nozzlePanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="6dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideRight"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nozzle"
            android:textColor="@color/safety_yellow"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp" />

        <!-- Joystick widget -->
        <com.firefighter.robotcontroller.JoystickView
            android:id="@+id/nozzleJoystick"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="6dp" />

        <!-- Hint text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nozzle_hint"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:gravity="center" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
